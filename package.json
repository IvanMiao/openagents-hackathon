{
  "name": "agentville",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.11.1",
  "workspaces": [
    "apps/*",
    "agents/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "dev:ui": "npm --workspace @agentville/ui run dev",
    "dev:reviewer": "npm --workspace @agentville/reviewer run dev",
    "dev:gas-estimator": "npm --workspace @agentville/gas-estimator run dev",
    "agentville": "npm --workspace @agentville/cli run dev"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "typescript": "^5.4.5"
  }
}
